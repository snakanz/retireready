# ============================================================
# RetireReady — Environment Variables
# Copy to .env.local for local development
# Add each to Cloudflare Pages > Settings > Environment Variables
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Project: retireready-v1-prod (ID: kcndebogwcxexkqeyesl)
# Found at: https://supabase.com/dashboard/project/kcndebogwcxexkqeyesl/settings/api

NEXT_PUBLIC_SUPABASE_URL=https://kcndebogwcxexkqeyesl.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── Stripe ───────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Webhook endpoint to register:
# POST https://retireready.pages.dev/api/webhook/stripe
# Events to listen for: checkout.session.completed

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://retireready.pages.dev

# ── Supabase Auth (Google OAuth) ─────────────────────────────
# Configure at: https://supabase.com/dashboard/project/kcndebogwcxexkqeyesl/auth/providers
# Google OAuth Redirect URL to whitelist:
# https://kcndebogwcxexkqeyesl.supabase.co/auth/v1/callback
# App callback URL: https://retireready.pages.dev/api/auth/callback
